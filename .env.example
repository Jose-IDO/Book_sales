DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-long-random-string-at-least-16-chars"

# Admin login password (plain text comparison — use a strong value)
ADMIN_PASSWORD="your-secure-admin-password"

# Where reservation emails go (defaults to SMTP_USER if unset)
ADMIN_NOTIFY_EMAIL="you@example.com"

# Optional: public site URL for links in emails
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# GitHub Pages static build: run `npm run build:pages` (outputs docs/ + dist/)
# Optional when building: GITHUB_PAGES_BASE_PATH=YourRepoName
# NEXT_PUBLIC_RESERVATION_EMAIL=seller@example.com

# SMTP (optional — without these, reservation emails are logged to the server console)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# EMAIL_FROM="Bookstore <noreply@example.com>"
