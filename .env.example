DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-long-random-string-at-least-16-chars"

# Admin login password (plain text comparison — use a strong value)
ADMIN_PASSWORD="your-secure-admin-password"

# Where reservation emails go (defaults to SMTP_USER if unset)
ADMIN_NOTIFY_EMAIL="you@example.com"

# Optional: public site URL for links in emails
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Firebase (client — safe to expose with NEXT_PUBLIC_) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=""
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
# NEXT_PUBLIC_FIREBASE_APP_ID=""
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# --- Firebase Admin (server only — never commit real JSON) ---
# Single-line JSON string (Vercel/hosting), or use GOOGLE_APPLICATION_CREDENTIALS locally:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# GOOGLE_APPLICATION_CREDENTIALS="C:\\path\\to\\serviceAccount.json"
#
# Reservations: if FIREBASE_SERVICE_ACCOUNT_JSON (or GOOGLE_APPLICATION_CREDENTIALS) is set,
# POST /api/reservations requires a Firebase ID token (Sign in on /login). Unset for local dev without Firebase.

# GitHub Pages static build: run `npm run build:pages` (outputs docs/ + dist/)
# Optional when building: GITHUB_PAGES_BASE_PATH=YourRepoName
# NEXT_PUBLIC_RESERVATION_EMAIL=seller@example.com

# SMTP (optional — without these, reservation emails are logged to the server console)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# EMAIL_FROM="Bookstore <noreply@example.com>"
